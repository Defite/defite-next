# GitHub OAuth2 for Admin
# Get these from https://github.com/settings/developers
# Create a new OAuth App and set the Authorization callback URL to:
# http://localhost:3000/api/auth/[...nextauth] (for local development)
# https://your-domain.com/api/auth/[...nextauth] (for production)

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# NextAuth Secret (used for JWT signing)
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key_here

# Your GitHub username that should have admin access
# Note: Currently any authenticated GitHub user can access the admin panel
# You can add additional checks in the middleware if needed
ADMIN_GITHUB_LOGIN=your_github_username
